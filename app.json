{
  "name": "API Music Bot",
  "description": "Telegram API Music Bot",
  "repository": "https://github.com/yourusername/API-MusicBot",
  "logo": "https://telegra.ph/file/example.jpg",
  "keywords": [
    "telegram",
    "music",
    "pyrogram",
    "pytgcalls"
  ],
  "stack": "heroku-24",
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],
  "env": {
    "API_ID": {
      "description": "Telegram API ID"
    },
    "API_HASH": {
      "description": "Telegram API Hash"
    },
    "BOT_TOKEN": {
      "description": "Bot Token"
    },
    "STRING_SESSION": {
      "description": "Assistant String Session"
    },
    "MONGO_DB_URI": {
      "description": "MongoDB Database URI"
    },
    "OWNER_ID": {
      "description": "Bot Owner ID"
    },
    "LOG_GROUP_ID": {
      "description": "Log Group ID",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
